{
  "name": "fonthabesha-workspace",
  "private": true,
  "workspaces": [
    "apps/api",
    "apps/web"
  ],
  "scripts": {
    "dev": "echo \"Run npm run dev:api and npm run dev:web in separate terminals.\"",
    "dev:api": "npm run start:dev --workspace @fonthabesha/api",
    "dev:web": "npm run dev --workspace @fonthabesha/web",
    "build": "npm run build:api",
    "build:api": "npm run build --workspace @fonthabesha/api",
    "build:web": "npm run build --workspace @fonthabesha/web",
    "start:api": "npm run start --workspace @fonthabesha/api",
    "seed:api": "npm run db:seed --workspace @fonthabesha/api",
    "prisma:generate:api": "npm run prisma:generate --workspace @fonthabesha/api",
    "prisma:validate:api": "npm run prisma:validate --workspace @fonthabesha/api"
  }
}
