{
  "name": "fonthabesha-workspace",
  "private": true,
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "npm run dev --workspace @fonthabesha/backend",
    "dev:frontend": "npm run dev --workspace @fonthabesha/frontend",
    "build": "npm run build:backend && npm run build:frontend",
    "build:backend": "npm run build --workspace @fonthabesha/backend",
    "build:frontend": "npm run build --workspace @fonthabesha/frontend",
    "start:backend": "npm run start --workspace @fonthabesha/backend",
    "seed:backend": "npm run db:seed --workspace @fonthabesha/backend",
    "prisma:generate:backend": "npm run prisma:generate --workspace @fonthabesha/backend",
    "prisma:validate:backend": "npm run prisma:validate --workspace @fonthabesha/backend"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
