{
  "name": "@fonthabesha/backend",
  "version": "1.0.0",
  "private": true,
  "description": "Backend scaffold for the Fonthabesha font-sharing platform.",
  "main": "dist/src/main.js",
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "db:seed": "tsx prisma/seed.ts",
    "dev": "npm run build && node dist/src/main.js",
    "dev:worker": "npm run build && MAIL_QUEUE_CONSUMER_ENABLED=true node dist/src/worker.js",
    "start": "node dist/src/main.js",
    "start:dev": "npm run build && node dist/src/main.js",
    "start:worker": "MAIL_QUEUE_CONSUMER_ENABLED=true node dist/src/worker.js",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:generate": "prisma generate",
    "prisma:validate": "prisma validate",
    "test": "npm run build && node --test --test-concurrency=1 test/**/*.test.js"
  },
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1020.0",
    "@aws-sdk/s3-request-presigner": "^3.1020.0",
    "@nestjs/common": "^11.1.17",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.17",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/platform-express": "^11.1.17",
    "@nestjs/terminus": "^11.1.1",
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "argon2": "^0.44.0",
    "bullmq": "^5.71.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "ioredis": "^5.10.1",
    "meilisearch": "^0.56.0",
    "nodemailer": "^7.0.6",
    "opentype.js": "^1.3.4",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@types/node": "^24.6.1",
    "@types/nodemailer": "^6.4.21",
    "@types/opentype.js": "^1.3.9",
    "prisma": "^7.6.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
